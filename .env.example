# Required — OpenAI-compatible API key
OPENAI_API_KEY=sk-...

# Optional — defaults to https://api.marketplace.novo-genai.com/v1
# OPENAI_BASE_URL=https://api.marketplace.novo-genai.com/v1

# Optional — enable post-report MLflow GenAI evaluation (adds LLM latency)
# EVAL_ENABLED=false
# EVAL_SUITES=groundedness,source_quality,coverage,factual_accuracy
# EVAL_JUDGE_MODEL=openai:/openai_gpt52
